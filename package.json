{
  "name": "@forceconstant/nano-gpt",
  "version": "0.1.4",
  "description": "NanoGPT provider plugin for OpenClaw — dynamic model catalog, auth, and usage tracking",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "plugin": "./openclaw.plugin.json",
    "extensions": [
      "./dist/index.js"
    ],
    "providers": [
      "nano-gpt"
    ],
    "compat": {
      "pluginApi": ">=2026.4.4",
      "minGatewayVersion": ">=2026.4.4"
    },
    "build": {
      "openclawVersion": "2026.4.8",
      "pluginSdkVersion": "2026.4.8"
    }
  },
  "keywords": [
    "openclaw",
    "provider",
    "nano-gpt",
    "ai"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=2026.4.4"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "openclaw": "^2026.4.5",
    "typescript": "^6.0.2",
    "vitest": "^3.1.4"
  }
}
